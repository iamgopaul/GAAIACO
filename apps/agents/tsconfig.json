{
  "extends": "@gaaia/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next.nosync/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-build.nosync/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
